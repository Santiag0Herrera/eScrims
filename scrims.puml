@startuml eScrims

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam linetype ortho
skinparam packageStyle rectangle

package "Aplicacion Swing" {
  class Main {
    + main(args: String[]): void
  }

  class EScrimsFrame {
    - usuarios: List<Usuario>
    - juegos: List<Juego>
    - regiones: List<Region>
    - scrims: List<Scrim>
    - contexts: Map<Scrim, ScrimContext>
    - eventBus: DomainEventBus
    + mostrarInterfaz(): void
    - configurarVentana(): void
    - construirPanelUsuarios(): JPanel
    - construirPanelScrims(): JPanel
    - construirPanelPostulaciones(): JPanel
    - construirPanelEmparejamiento(): JPanel
    - construirPanelPosteriorScrim(): JPanel
    - configurarEventos(): void
    - mostrarAlertaFirebase(message: String): void
    - refrescarTodo(): void
    - avanzarEstadoScrim(scrim: Scrim): void
    - ejecutarAccionEstado(action: String, scrim: Scrim): void
  }
}

package "Dominio" {
  class Usuario {
    - id: String
    - username: String
    - email: String
    - passwordHash: String
    - estadoVerificacion: String
    - disponibilidadHoraria: String
    - regionPrincipal: Region
    - perfiles: List<PerfilJuego>
    - notificaciones: List<Notificacion>
    + registrarse(): void
    + actualizarPerfil(username: String, email: String, disponibilidadHoraria: String, regionPrincipal: Region): void
    + agregarPerfilJuego(perfil: PerfilJuego): void
    + reemplazarPerfilJuego(perfilActual: PerfilJuego, perfilNuevo: PerfilJuego): void
    + postularse(scrim: Scrim, rolDeseado: String): Postulacion
    + confirmarParticipacion(scrim: Scrim): Confirmacion
    + reportarConducta(usuarioReportado: Usuario, scrim: Scrim, motivo: String): ReporteConducta
    + recibirNotificacion(notificacion: Notificacion): void
    + perfilPara(juego: Juego): PerfilJuego
  }

  class PerfilJuego {
    - id: String
    - juego: Juego
    - rango: String
    - mmr: Integer
    - rolesPreferidos: List<String>
    + actualizarRango(nuevoRango: String): void
    + actualizarMMR(nuevoMMR: Integer): void
  }

  class Juego {
    - id: String
    - nombre: String
    - descripcion: String
    + validarFormato(modalidad: String): Boolean
  }

  class Region {
    - id: String
    - nombre: String
    - servidor: String
    + validarLatencia(latencia: Integer): Boolean
  }

  class Scrim {
    - id: String
    - juego: Juego
    - region: Region
    - fechaHora: DateTime
    - duracionMinutos: Integer
    - mmrMinimo: Integer
    - mmrMaximo: Integer
    - latenciaMaxima: Integer
    - modalidad: String
    - estadoActual: String
    - cantidadJugadores: Integer
    - cantidadEquipos: Integer
    - jugadoresPorEquipo: Integer
    - formato: String
    - equipos: List<Equipo>
    - postulaciones: List<Postulacion>
    - confirmaciones: List<Confirmacion>
    - notificaciones: List<Notificacion>
    - estadisticas: List<Estadistica>
    - feedback: List<ComentarioFeedback>
    - reportes: List<ReporteConducta>
    + abrirPostulaciones(): void
    + cerrarPostulaciones(): void
    + iniciar(): void
    + finalizar(): void
    + cancelar(): void
    + cambiarEstado(nuevoEstado: String): void
    + recibirPostulacion(postulacion: Postulacion): void
    + agregarConfirmacion(confirmacion: Confirmacion): void
    + agregarEstadistica(estadistica: Estadistica): void
    + agregarFeedback(comentario: ComentarioFeedback): void
    + agregarReporte(reporte: ReporteConducta): void
    + agregarNotificacion(notificacion: Notificacion): void
    + reiniciarEquipos(): void
    + tieneCupoCompleto(): Boolean
  }

  class Equipo {
    - id: String
    - lado: String
    - participaciones: List<Participacion>
    + agregarJugador(usuario: Usuario, rol: String): Participacion
    + quitarJugador(participacion: Participacion): void
    + asignarCapitan(participacion: Participacion): void
    + contieneUsuario(usuario: Usuario): Boolean
    + limpiarParticipaciones(): void
    + cantidadJugadores(): Integer
  }

  class Participacion {
    - id: String
    - usuario: Usuario
    - rol: String
    - esCapitan: Boolean
    - esSuplente: Boolean
    - estado: String
    - fechaIngreso: DateTime
    + cambiarRol(nuevoRol: String): void
    + abandonar(): void
    + asignarCapitan(): void
  }

  class Postulacion {
    - id: String
    - usuario: Usuario
    - scrim: Scrim
    - rolDeseado: String
    - estado: String
    - fechaPostulacion: DateTime
    + aceptar(): void
    + rechazar(): void
    + confirmarAsistencia(): Confirmacion
  }

  class Confirmacion {
    - id: String
    - usuario: Usuario
    - scrim: Scrim
    - confirmado: Boolean
    - fechaConfirmacion: DateTime
    + confirmar(): void
    + revocar(): void
    + estaConfirmado(): Boolean
  }

  class Notificacion {
    - id: String
    - tipo: String
    - canal: String
    - payload: String
    - estado: String
    - fechaEnvio: DateTime
    + enviar(): void
    + reintentar(): void
  }

  class Estadistica {
    - id: String
    - usuario: Usuario
    - scrim: Scrim
    - kills: Integer
    - deaths: Integer
    - assists: Integer
    - mvp: Boolean
    - observaciones: String
    - resultado: String
    + calcularKDA(): Decimal
  }

  class ComentarioFeedback {
    - id: String
    - usuario: Usuario
    - scrim: Scrim
    - comentario: String
    - rating: Integer
    - estadoModeracion: String
    - fechaCreacion: DateTime
    + aprobar(): void
    + rechazar(): void
  }

  class ReporteConducta {
    - id: String
    - scrim: Scrim
    - reportante: Usuario
    - reportado: Usuario
    - motivo: String
    - estado: String
    - sancion: String
    - fechaCreacion: DateTime
    + procesar(): void
    + resolver(sancion: String): void
    + obtenerReportante(): Usuario
    + obtenerReportado(): Usuario
  }
}

package "State" {
  class ScrimContext {
    - state: ScrimState
    - scrim: Scrim
    - eventBus: DomainEventBus
    + cambiarEstado(nuevoEstado: ScrimState): void
    + postular(): void
    + confirmar(): void
    + iniciar(): void
    + finalizar(): void
    + cancelar(): void
  }

  interface ScrimState {
    + postular(context: ScrimContext): void
    + confirmar(context: ScrimContext): void
    + iniciar(context: ScrimContext): void
    + finalizar(context: ScrimContext): void
    + cancelar(context: ScrimContext): void
    + nombre(): String
    + canalNotificacion(): String
  }

  class BuscandoJugadoresState {
    - nombre: String
    + postular(context: ScrimContext): void
    + confirmar(context: ScrimContext): void
    + iniciar(context: ScrimContext): void
    + finalizar(context: ScrimContext): void
    + cancelar(context: ScrimContext): void
    + nombre(): String
    + canalNotificacion(): String
  }

  class LobbyArmadoState {
    - nombre: String
    + postular(context: ScrimContext): void
    + confirmar(context: ScrimContext): void
    + iniciar(context: ScrimContext): void
    + finalizar(context: ScrimContext): void
    + cancelar(context: ScrimContext): void
    + nombre(): String
    + canalNotificacion(): String
  }

  class ConfirmadoState {
    - nombre: String
    + postular(context: ScrimContext): void
    + confirmar(context: ScrimContext): void
    + iniciar(context: ScrimContext): void
    + finalizar(context: ScrimContext): void
    + cancelar(context: ScrimContext): void
    + nombre(): String
    + canalNotificacion(): String
  }

  class EnJuegoState {
    - nombre: String
    + postular(context: ScrimContext): void
    + confirmar(context: ScrimContext): void
    + iniciar(context: ScrimContext): void
    + finalizar(context: ScrimContext): void
    + cancelar(context: ScrimContext): void
    + nombre(): String
    + canalNotificacion(): String
  }

  class FinalizadoState {
    - nombre: String
    + postular(context: ScrimContext): void
    + confirmar(context: ScrimContext): void
    + iniciar(context: ScrimContext): void
    + finalizar(context: ScrimContext): void
    + cancelar(context: ScrimContext): void
    + nombre(): String
    + canalNotificacion(): String
  }

  class CanceladoState {
    - nombre: String
    + postular(context: ScrimContext): void
    + confirmar(context: ScrimContext): void
    + iniciar(context: ScrimContext): void
    + finalizar(context: ScrimContext): void
    + cancelar(context: ScrimContext): void
    + nombre(): String
    + canalNotificacion(): String
  }
}

package "Strategy" {
  interface MatchmakingStrategy {
    + seleccionarJugadores(scrim: Scrim): List<Postulacion>
  }

  class ByMMRStrategy {
    - toleranciaMMR: Integer
    + seleccionarJugadores(scrim: Scrim): List<Postulacion>
  }

  class ByLatencyStrategy {
    - latenciaObjetivo: Integer
    + seleccionarJugadores(scrim: Scrim): List<Postulacion>
  }

  class ByHistoryStrategy {
    - partidasMinimas: Integer
    + seleccionarJugadores(scrim: Scrim): List<Postulacion>
  }

  class MatchmakingService {
    - strategy: MatchmakingStrategy
    + setStrategy(strategy: MatchmakingStrategy): void
    + ejecutarMatchmaking(scrim: Scrim): List<Postulacion>
  }
}

package "Observer y Factory" {
  class DomainEvent {
    - id: String
    - timestamp: DateTime
    - tipo: String
    - canal: String
    - payload: Map<String, String>
    + describir(): String
  }

  interface Subscriber {
    + onEvent(event: DomainEvent): void
  }

  class DomainEventBus {
    - subscribers: List<Subscriber>
    + subscribe(subscriber: Subscriber): void
    + unsubscribe(subscriber: Subscriber): void
    + publish(event: DomainEvent): void
  }

  class NotificationSubscriber {
    - factory: NotifierFactory
    + onEvent(event: DomainEvent): void
  }

  interface Notifier {
    + send(event: DomainEvent): void
  }

  interface NotifierFactory {
    + createNotifier(canal: String): Notifier
  }

  class ChannelNotifierFactory {
    - canalesSoportados: Map<String, Supplier<Notifier>>
    + createNotifier(canal: String): Notifier
  }

  class EmailNotifier {
    - provider: ExternalNotificationProvider
    + send(event: DomainEvent): void
  }

  class PushNotifier {
    - provider: ExternalNotificationProvider
    + send(event: DomainEvent): void
    - mensajePara(event: DomainEvent): String
  }

  class DiscordNotifier {
    - provider: ExternalNotificationProvider
    + send(event: DomainEvent): void
  }
}

package "Adapter" {
  interface ExternalNotificationProvider {
    + sendMessage(destination: String, payload: String): void
  }

  class FirebaseAdapter {
    - api: FirebaseAPI
    + sendMessage(destination: String, payload: String): void
  }

  class FirebaseAPI {
    - projectId: String
    - logger: Consumer<String>
    + sendPush(token: String, message: String): void
  }

  class SendGridAdapter {
    - api: SendGridAPI
    + sendMessage(destination: String, payload: String): void
  }

  class SendGridAPI {
    - apiKey: String
    - logger: Consumer<String>
    + sendEmail(email: String, subject: String, body: String): void
  }

  class DiscordAdapter {
    - api: DiscordAPI
    + sendMessage(destination: String, payload: String): void
  }

  class DiscordAPI {
    - webhookUrl: String
    - logger: Consumer<String>
    + postToChannel(channelId: String, message: String): void
  }
}

Main ..> EScrimsFrame : mostrarInterfaz()
EScrimsFrame "1" o-- "0..*" Usuario
EScrimsFrame "1" o-- "0..*" Scrim
EScrimsFrame "1" o-- "0..*" ScrimContext
EScrimsFrame "1" o-- "1" DomainEventBus
EScrimsFrame ..> FirebaseAPI : mostrarAlertaFirebase

Usuario "1" *-- "0..*" PerfilJuego
Usuario "1" *-- "0..*" Notificacion
Region "1" <-- "0..*" Usuario
Juego "1" <-- "0..*" PerfilJuego
Juego "1" <-- "0..*" Scrim
Region "1" <-- "0..*" Scrim
Scrim "1" *-- "2..*" Equipo
Scrim "1" o-- "0..*" Postulacion
Scrim "1" o-- "0..*" Confirmacion
Scrim "1" o-- "0..*" Estadistica
Scrim "1" o-- "0..*" ComentarioFeedback
Scrim "1" o-- "0..*" ReporteConducta
Equipo "1" *-- "0..*" Participacion
Usuario "1" <-- "0..*" Participacion
Usuario "1" <-- "0..*" Postulacion
Usuario "1" <-- "0..*" Confirmacion

ScrimContext "1" *-- "1" Scrim
ScrimContext "1" o-- "1" ScrimState
ScrimContext "1" o-- "1" DomainEventBus
BuscandoJugadoresState ..|> ScrimState
LobbyArmadoState ..|> ScrimState
ConfirmadoState ..|> ScrimState
EnJuegoState ..|> ScrimState
FinalizadoState ..|> ScrimState
CanceladoState ..|> ScrimState

MatchmakingService "1" o-- "1" MatchmakingStrategy
ByMMRStrategy ..|> MatchmakingStrategy
ByLatencyStrategy ..|> MatchmakingStrategy
ByHistoryStrategy ..|> MatchmakingStrategy

DomainEventBus "1" o-- "0..*" Subscriber
NotificationSubscriber ..|> Subscriber
NotificationSubscriber "1" o-- "1" NotifierFactory
ChannelNotifierFactory ..|> NotifierFactory
EmailNotifier ..|> Notifier
PushNotifier ..|> Notifier
DiscordNotifier ..|> Notifier

FirebaseAdapter ..|> ExternalNotificationProvider
SendGridAdapter ..|> ExternalNotificationProvider
DiscordAdapter ..|> ExternalNotificationProvider
FirebaseAdapter "1" o-- "1" FirebaseAPI
PushNotifier "1" o-- "1" FirebaseAdapter : PUSH
EmailNotifier "1" o-- "1" SendGridAdapter : EMAIL
DiscordNotifier "1" o-- "1" DiscordAdapter : DISCORD

note right of FirebaseAPI
  En la app Swing, logger apunta a
  EScrimsFrame.mostrarAlertaFirebase.
  Por Adapter, el canal PUSH termina
  como alerta interna de Java Swing
  con texto visible para usuarios.
end note

@enduml
